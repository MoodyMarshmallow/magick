{
  "name": "magick",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:stack": "concurrently -k -n server,web -c auto \"bun run server:dev\" \"wait-on tcp:8787 && bun run web:dev\"",
    "desktop:dev": "concurrently -k -n web,desktop -c auto \"bun run web:dev\" \"wait-on tcp:4173 && cross-env MAGICK_RENDERER_URL=http://localhost:4173 bun run desktop:main\"",
    "desktop:main": "nodemon --watch apps/desktop/src/main --watch apps/desktop/src/preload --ext ts --signal SIGTERM --exec \"cross-env NODE_OPTIONS=--import=tsx electron apps/desktop/src/main/main.ts\"",
    "desktop:start": "cross-env NODE_OPTIONS=--import=tsx electron apps/desktop/src/main/main.ts",
    "fmt": "biome format --write .",
    "lint": "biome check .",
    "server:dev": "bun run --cwd apps/server dev",
    "server:start": "bun run --cwd apps/server start",
    "start": "concurrently -k -n server,web -c auto \"bun run server:start\" \"wait-on tcp:8787 && bun run web:dev\"",
    "terminal": "./scripts/terminal",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "web:dev": "bun run --cwd apps/web dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.2.4",
    "better-sqlite3": "^12.8.0",
    "bun-types": "^1.2.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "effect": "^3.13.11",
    "jsdom": "^29.0.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1",
    "wait-on": "^9.0.4",
    "ws": "^8.18.1"
  },
  "dependencies": {
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@proj-airi/font-departure-mono": "^0.9.0-alpha.34",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.7",
    "@tiptap/core": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "katex": "^0.16.44",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vite": "^8.0.3",
    "zustand": "^5.0.12"
  }
}
