{
  "name": "magick",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:stack": "concurrently -k -n server,web -c auto \"bun run server:dev\" \"wait-on tcp:8787 && bun run web:dev\"",
    "desktop:dev": "concurrently -k -n web,desktop -c auto \"bun run web:dev\" \"wait-on tcp:4173 && cross-env MAGICK_RENDERER_URL=http://localhost:4173 bun run desktop:main\"",
    "desktop:main": "bun run --cwd apps/desktop dev",
    "desktop:start": "bun run --cwd apps/desktop start",
    "fmt": "biome format --write .",
    "knip": "knip",
    "lint": "biome check .",
    "server:dev": "bun run --cwd apps/server dev",
    "server:start": "bun run --cwd apps/server start",
    "start": "concurrently -k -n server,web -c auto \"bun run server:start\" \"wait-on tcp:8787 && bun run web:dev\"",
    "terminal": "./scripts/terminal",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "web:dev": "bun run --cwd apps/web dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.2.4",
    "bun-types": "^1.2.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "knip": "^6.3.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1",
    "wait-on": "^9.0.4"
  }
}
