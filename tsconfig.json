{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@magick/contracts/chat": ["packages/contracts/src/chat.ts"],
      "@magick/contracts/provider": ["packages/contracts/src/provider.ts"],
      "@magick/contracts/ws": ["packages/contracts/src/ws.ts"],
      "@magick/shared/errors": ["packages/shared/src/errors.ts"],
      "@magick/shared/id": ["packages/shared/src/id.ts"],
      "@magick/shared/time": ["packages/shared/src/time.ts"]
    },
    "types": ["bun-types", "vitest/globals"]
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts"]
}
